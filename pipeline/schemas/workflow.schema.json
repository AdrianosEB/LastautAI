{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowDefinition",
  "description": "Structured workflow definition generated from natural language input",
  "type": "object",
  "required": ["name", "trigger", "steps"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable workflow title"
    },
    "trigger": {
      "type": "object",
      "required": ["type", "config"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["schedule", "event", "manual", "webhook"]
        },
        "config": {
          "type": "object",
          "properties": {
            "cron": { "type": ["string", "null"] },
            "event_type": { "type": ["string", "null"] },
            "webhook_path": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "action", "description"],
        "properties": {
          "id": { "type": "string" },
          "action": { "type": "string" },
          "description": { "type": "string" },
          "inputs": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "outputs": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "conditions": {
            "type": "object",
            "properties": {
              "if": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["string", "number", "boolean", "array"]
          },
          "default": {},
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "error_handling": {
      "type": "object",
      "properties": {
        "default_retry": {
          "type": "object",
          "properties": {
            "max_attempts": { "type": "integer", "minimum": 1 },
            "backoff": { "type": "string", "enum": ["fixed", "exponential"] },
            "delay_seconds": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "on_failure": {
          "type": "string",
          "enum": ["stop", "skip", "notify"]
        },
        "step_overrides": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "max_attempts": { "type": "integer", "minimum": 1 },
              "on_failure": { "type": "string", "enum": ["stop", "skip", "notify"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
